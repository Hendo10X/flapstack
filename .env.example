PORT=8080
DATABASE_URL=host=localhost user=postgres password=postgres dbname=flapstack port=5432 sslmode=disable
FRONTEND_ORIGIN=http://localhost:3000
JWT_SECRET=change-me

# Polar billing (https://polar.sh) — webhook signature secret + product ID.
# The Next.js side reads NEXT_PUBLIC_POLAR_CHECKOUT_URL to render the upgrade button.
POLAR_WEBHOOK_SECRET=
POLAR_ACCESS_TOKEN=
POLAR_PRODUCT_ID=

# Override the per-IP monthly AI free-tier limit. Defaults to 10.
FREE_AI_LIMIT=

# AES-256 key for vault encryption-at-rest. 64 hex chars (32 bytes).
# Generate with: openssl rand -hex 32
# If unset, a dev fallback key is used — DO NOT ship that to production.
ENCRYPTION_KEY=

